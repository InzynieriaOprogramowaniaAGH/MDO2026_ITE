[0.670, "o", "\u001b[1m\u001b[31m\"\u001b[1m\u001b[31mO\u001b[1m\u001b[31mh\u001b[1m\u001b[31m,\u001b[1m\u001b[31m \u001b[1m\u001b[31mc\u001b[1m\u001b[31mo\u001b[1m\u001b[31mn\u001b[1m\u001b[31mt\u001b[1m\u001b[31ma\u001b[1m\u001b[31mi\u001b[1m\u001b[31mn\u001b[1m\u001b[31me\u001b[1m\u001b[31mr\u001b[1m\u001b[31m \u001b[1m\u001b[31mi\u001b[1m\u001b[31ms\u001b[1m\u001b[31m \u001b[1m\u001b[31mm\u001b[1m\u001b[31mi\u001b[1m\u001b[31mn\u001b[1m\u001b[31mi\u001b[1m\u001b[31mm\u001b[1m\u001b[31ma\u001b[1m\u001b[31ml\u001b[1m\u001b[31m!\u001b[1m\u001b[31m \u001b[1m\u001b[31mB\u001b[1m\u001b[31mu\u001b[1m\u001b[31mt\u001b[1m\u001b[31m \u001b[1m\u001b[31mi\u001b[1m\u001b[31mt\u001b[1m\u001b[31m \u001b[1m\u001b[31mw\u001b[1m\u001b[31mo\u001b[1m\u001b[31mr\u001b[1m\u001b[31mk\u001b[1m\u001b[31me\u001b[1m\u001b[31md\u001b[1m\u001b[31m \u001b[1m\u001b[31ma\u001b[1m\u001b[31mn\u001b[1m\u001b[31my\u001b[1m\u001b[31mw\u001b[1m\u001b[31ma\u001b[1m\u001b[31my\u001b[0m\u001b[39m\u001b[46D"]
