[0.773, "o", "\u001b[0m\u001b[39m \u001b[1m\u001b[31mO\u001b[1m\u001b[31mh\u001b[1m\u001b[31m,\u001b[0m\u001b[39m\u001b[0m\u001b[39m \u001b[0m\u001b[39mc\u001b[0m\u001b[39mo\u001b[0m\u001b[39mn\u001b[0m\u001b[39mt\u001b[0m\u001b[39ma\u001b[0m\u001b[39mi\u001b[0m\u001b[39mn\u001b[0m\u001b[39me\u001b[0m\u001b[39mr\u001b[0m\u001b[39m \u001b[0m\u001b[39mi\u001b[0m\u001b[39ms\u001b[0m\u001b[39m \u001b[0m\u001b[39mm\u001b[0m\u001b[39mi\u001b[0m\u001b[39mn\u001b[0m\u001b[39mi\u001b[0m\u001b[39mm\u001b[0m\u001b[39ma\u001b[0m\u001b[39ml\u001b[0m\u001b[39m!\u001b[0m\u001b[39m \u001b[0m\u001b[39mB\u001b[0m\u001b[39mu\u001b[0m\u001b[39mt\u001b[0m\u001b[39m \u001b[0m\u001b[39mi\u001b[0m\u001b[39mt\u001b[0m\u001b[39m \u001b[0m\u001b[39mw\u001b[0m\u001b[39mo\u001b[0m\u001b[39mr\u001b[0m\u001b[39mk\u001b[0m\u001b[39me\u001b[0m\u001b[39md\u001b[0m\u001b[39m \u001b[0m\u001b[39ma\u001b[0m\u001b[39mn\u001b[0m\u001b[39my\u001b[0m\u001b[39mw\u001b[0m\u001b[39ma\u001b[0m\u001b[39my\u001b[0m\u001b[39m \u001b[48D"]
[0.390, "o", "\u001b[1m\u001b[31mO\u001b[1m\u001b[31mh\u001b[1m\u001b[31m,\u001b[0m\u001b[39m\u001b[0m\u001b[39m container is minimal! But it worked anyway \u001b[47D"]
[2.433, "o", "\u001b[1m\u001b[31m[\u001b[1m\u001b[31mO\u001b[1m\u001b[31mh\u001b[1m\u001b[31m,\u001b[0m\u001b[39m container is minimal! But it worked anyway\u001b[46D"]
