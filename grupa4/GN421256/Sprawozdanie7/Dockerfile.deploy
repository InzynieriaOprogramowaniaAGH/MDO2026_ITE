# Dockerfile.deploy
#
# Kontener docelowy (deploy) różny od BLDR: bez gita i bez dev-deps,
# zawiera tylko wynik budowy (dist) i minimalne metadane.
ARG BLDR_IMAGE
FROM ${BLDR_IMAGE} AS bldr

FROM node:20-bullseye-slim

WORKDIR /app

COPY --from=bldr /app/package.json ./package.json
COPY --from=bldr /app/dist ./dist

CMD ["sh", "-lc", "test -d dist && echo 'SMOKE OK: dist exists' && ls -la dist | head -n 50"]

