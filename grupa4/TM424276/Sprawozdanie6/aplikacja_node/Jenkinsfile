pipeline {
    agent any
    
    environment {
        APP_VERSION = "1.0.${env.BUILD_ID}"
        IMAGE_NAME = "express-api"
        // Wskazujemy Jenkinsowi, gdzie ma pracować
        WORK_DIR = "grupa4/TM424276/Sprawozdanie6/aplikacja_node"
    }

    stages {
        stage('Budowanie i Testowanie') {
            steps {
                dir("${WORK_DIR}") {
                    sh 'docker build --target test -t ${IMAGE_NAME}-test .'
                }
            }
        }
        
        stage('Budowanie Finalnego Obrazu (Deploy)') {
            steps {
                dir("${WORK_DIR}") {
                    sh 'docker build --target deploy -t ${IMAGE_NAME}:${APP_VERSION} .'
                }
            }
        }

        stage('Smoke Test (Weryfikacja)') {
            steps {
                dir("${WORK_DIR}") {
                    sh 'docker run -d -p 5000:5000 --name smoke-test-app ${IMAGE_NAME}:${APP_VERSION}'
                    
                    // Dajemy mu 5 sekund na start
                    sleep 5
                    
                    // Pobieramy prawdziwy adres IP kontenera i wysyłamy tam zapytanie
                    sh 'APP_IP=$(docker inspect -f "{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}" smoke-test-app) && curl -f http://$APP_IP:5000/'
                }
            }
            post {
                always {
                    sh 'docker rm -f smoke-test-app'
                }
            }
        }

        stage('Publikacja Artefaktu') {
            steps {
                dir("${WORK_DIR}") {
                    sh 'docker save ${IMAGE_NAME}:${APP_VERSION} | gzip > ${IMAGE_NAME}-v${APP_VERSION}.tar.gz'
                    archiveArtifacts artifacts: '*.tar.gz', fingerprint: true
                }
            }
        }
    }
}
